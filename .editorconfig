root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[*.{ts,js,mjs,cjs,vue,css,html}]
indent_size = 2

[*.ps1]
end_of_line = crlf

[*.{png,ico,icns,exe,dll,pak,bin,dat}]
insert_final_newline = false
